[Unit]
Description=Hermes Agent Gateway - Messaging Platform Integration
After=network-online.target
Wants=network-online.target
StartLimitIntervalSec=0

[Service]
Type=simple
ExecStart=/home/vearnx/.hermes/hermes-agent/venv/bin/python -m hermes_cli.main gateway run --replace
WorkingDirectory=/home/vearnx/.hermes/hermes-agent
Environment="PATH=/home/vearnx/.hermes/hermes-agent/venv/bin:/home/vearnx/.hermes/hermes-agent/node_modules/.bin:/usr/bin:/home/vearnx/.local/bin:/home/vearnx/.cargo/bin:/home/vearnx/.npm-global/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin"
Environment="VIRTUAL_ENV=/home/vearnx/.hermes/hermes-agent/venv"
Environment="HERMES_HOME=/home/vearnx/.hermes"
Restart=always
RestartSec=5
RestartMaxDelaySec=300
RestartSteps=5
RestartForceExitStatus=75
KillMode=mixed
KillSignal=SIGTERM
ExecReload=/bin/kill -USR1 $MAINPID
TimeoutStopSec=210
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=default.target
